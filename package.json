{
	"name": "plaza",
	"type": "module",
	"private": true,
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev --host",
		"start": "node .output/server/index.mjs",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"typecheck": "nuxi typecheck",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"validate": "npm run lint && npm run typecheck && npm run test",
		"predeploy": "npm run validate && npm run build",
		"health-check": "node scripts/health-check.mjs",
		"backup:db:local": "npx tsx scripts/backup-db-local.ts",
		"backup:db:prod": "npx tsx scripts/backup-db-prod.ts",
		"restore:db": "npx tsx scripts/restore-db.ts",
		"sync:prod-to-local": "npx tsx scripts/sync-prod-to-local.ts",
		"cleanup:uploads:dry": "npx tsx scripts/cleanup-uploads-prod.ts --dry-run",
		"cleanup:uploads": "npx tsx scripts/cleanup-uploads-prod.ts"
	},
	"dependencies": {
		"@formkit/icons": "^1.7.2",
		"@formkit/nuxt": "^1.7.2",
		"@formkit/themes": "^1.7.2",
		"@nuxt/fonts": "^0.14.0",
		"@nuxtjs/i18n": "^10.2.1",
		"@nuxtjs/sitemap": "^8.0.8",
		"@panzoom/panzoom": "^4.6.1",
		"@tiptap/extension-image": "^3.20.0",
		"@tiptap/extension-link": "^3.20.0",
		"@tiptap/extension-table": "^3.20.0",
		"@tiptap/extension-table-cell": "^3.20.0",
		"@tiptap/extension-table-header": "^3.20.0",
		"@tiptap/extension-table-row": "^3.20.0",
		"@tiptap/extension-text-align": "^3.20.0",
		"@tiptap/extension-underline": "^3.20.0",
		"@tiptap/starter-kit": "^3.20.0",
		"@tiptap/vue-3": "^3.20.0",
		"@types/bcrypt": "^6.0.0",
		"bcrypt": "^6.0.0",
		"bcryptjs": "^3.0.3",
		"dompurify": "^3.3.3",
		"jsonwebtoken": "^9.0.3",
		"jspdf": "^4.2.1",
		"mongoose": "^9.1.5",
		"nuxt": "^4.3.0",
		"swiper": "^12.1.2",
		"vue": "^3.5.27",
		"vue-router": "^4.6.4",
		"vuedraggable": "^4.1.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@nuxt/eslint": "^1.15.2",
		"@nuxt/test-utils": "^3.23.0",
		"@nuxtjs/tailwindcss": "^6.14.0",
		"@types/bcryptjs": "^2.4.6",
		"@types/dompurify": "^3.0.5",
		"@types/jsonwebtoken": "^9.0.10",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"happy-dom": "^20.4.0",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4",
		"vue-tsc": "^3.2.4"
	}
}
