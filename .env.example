# ===========================================
# OC Plaza Liberec - Environment Variables
# ===========================================
# Zkopírujte jako .env a upravte hodnoty
# Tyto proměnné nastavte v Coolify jako Variables
#
# Nuxt automaticky parsuje NUXT_ prefix:
# - NUXT_* = runtimeConfig (server-only)
# - NUXT_PUBLIC_* = runtimeConfig.public (exposed to client)
# ===========================================

# -------------------------------------------
# DATABASE
# -------------------------------------------
# MongoDB connection string (MongoDB Atlas nebo lokální)
NUXT_MONGO_URI=mongodb://localhost:27017/plaza
# Pro produkci (Coolify):
# NUXT_MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/plaza?retryWrites=true&w=majority

# -------------------------------------------
# AUTHENTICATION
# -------------------------------------------
# JWT secret - ZMĚŇTE V PRODUKCI! (min 32 znaků)
NUXT_JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
# Platnost JWT tokenu
NUXT_JWT_EXPIRES_IN=7d

# -------------------------------------------
# PUBLIC - SITE INFO
# -------------------------------------------
# URL webu (pro SSR, SEO, sitemap)
NUXT_PUBLIC_SITE_URL=https://ocplazaliberec.cz
# Název webu
NUXT_PUBLIC_SITE_NAME=OC Plaza Liberec
# Popis webu (SEO)
NUXT_PUBLIC_SITE_DESCRIPTION=Obchodní centrum Plaza Liberec - nakupování, zábava a služby na jednom místě
# Výchozí jazyk (cs/en)
NUXT_PUBLIC_DEFAULT_LOCALE=cs

# -------------------------------------------
# NODE ENVIRONMENT
# -------------------------------------------
NODE_ENV=production

# -------------------------------------------
# OPTIONAL - MONITORING
# -------------------------------------------
# Sentry DSN pro error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx

# -------------------------------------------
# OPTIONAL - COOLIFY SPECIFIC
# -------------------------------------------
# Port (Coolify nastavuje automaticky)
# PORT=3000
# Host (pro Docker)
# HOST=0.0.0.0
